digraph {
	rankdir=LR;
	node [shape=plaintext];
	subgraph cluster__scls_file {
		label="SclsFile";
		graph[style=dotted];

		scls_file__seq [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
			<TR><TD BGCOLOR="#E0FFE0">pos</TD><TD BGCOLOR="#E0FFE0">size</TD><TD BGCOLOR="#E0FFE0">type</TD><TD BGCOLOR="#E0FFE0">id</TD></TR>
			<TR><TD PORT="record_pos">0</TD><TD PORT="record_size">...</TD><TD>SclsRecord</TD><TD PORT="record_type">record</TD></TR>
			<TR><TD COLSPAN="4" PORT="record__repeat">repeat to end of stream</TD></TR>
		</TABLE>>];
		subgraph cluster__digest {
			label="SclsFile::Digest";
			graph[style=dotted];

			digest__seq [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
				<TR><TD BGCOLOR="#E0FFE0">pos</TD><TD BGCOLOR="#E0FFE0">size</TD><TD BGCOLOR="#E0FFE0">type</TD><TD BGCOLOR="#E0FFE0">id</TD></TR>
				<TR><TD PORT="data_pos">0</TD><TD PORT="data_size">28</TD><TD></TD><TD PORT="data_type">data</TD></TR>
			</TABLE>>];
		}
		subgraph cluster__rec_manifest {
			label="SclsFile::RecManifest";
			graph[style=dotted];

			rec_manifest__seq [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
				<TR><TD BGCOLOR="#E0FFE0">pos</TD><TD BGCOLOR="#E0FFE0">size</TD><TD BGCOLOR="#E0FFE0">type</TD><TD BGCOLOR="#E0FFE0">id</TD></TR>
				<TR><TD PORT="total_entries_pos">0</TD><TD PORT="total_entries_size">8</TD><TD>u8be</TD><TD PORT="total_entries_type">total_entries</TD></TR>
				<TR><TD PORT="total_chunks_pos">8</TD><TD PORT="total_chunks_size">8</TD><TD>u8be</TD><TD PORT="total_chunks_type">total_chunks</TD></TR>
				<TR><TD PORT="summary_pos">16</TD><TD PORT="summary_size">...</TD><TD>Summary</TD><TD PORT="summary_type">summary</TD></TR>
				<TR><TD PORT="namespace_info_pos">...</TD><TD PORT="namespace_info_size">...</TD><TD>NamespaceInfo</TD><TD PORT="namespace_info_type">namespace_info</TD></TR>
				<TR><TD COLSPAN="4" PORT="namespace_info__repeat">repeat until _.len_ns == 0</TD></TR>
				<TR><TD PORT="prev_manifest_pos">...</TD><TD PORT="prev_manifest_size">8</TD><TD>u8be</TD><TD PORT="prev_manifest_type">prev_manifest</TD></TR>
				<TR><TD PORT="root_hash_pos">...</TD><TD PORT="root_hash_size">28</TD><TD>Digest</TD><TD PORT="root_hash_type">root_hash</TD></TR>
				<TR><TD PORT="offset_pos">...</TD><TD PORT="offset_size">4</TD><TD>u4be</TD><TD PORT="offset_type">offset</TD></TR>
			</TABLE>>];
		}
		subgraph cluster__ns_info {
			label="SclsFile::NsInfo";
			graph[style=dotted];

			ns_info__seq [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
				<TR><TD BGCOLOR="#E0FFE0">pos</TD><TD BGCOLOR="#E0FFE0">size</TD><TD BGCOLOR="#E0FFE0">type</TD><TD BGCOLOR="#E0FFE0">id</TD></TR>
				<TR><TD PORT="entries_count_pos">0</TD><TD PORT="entries_count_size">8</TD><TD>u8be</TD><TD PORT="entries_count_type">entries_count</TD></TR>
				<TR><TD PORT="chunks_count_pos">8</TD><TD PORT="chunks_count_size">8</TD><TD>u8be</TD><TD PORT="chunks_count_type">chunks_count</TD></TR>
				<TR><TD PORT="namespaces_bytes_pos">16</TD><TD PORT="namespaces_bytes_size">_parent.len_ns</TD><TD>str(UTF-8)</TD><TD PORT="namespaces_bytes_type">namespaces_bytes</TD></TR>
				<TR><TD PORT="digest_pos">...</TD><TD PORT="digest_size">28</TD><TD>Digest</TD><TD PORT="digest_type">digest</TD></TR>
			</TABLE>>];
		}
		subgraph cluster__rec_chunk {
			label="SclsFile::RecChunk";
			graph[style=dotted];

			rec_chunk__seq [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
				<TR><TD BGCOLOR="#E0FFE0">pos</TD><TD BGCOLOR="#E0FFE0">size</TD><TD BGCOLOR="#E0FFE0">type</TD><TD BGCOLOR="#E0FFE0">id</TD></TR>
				<TR><TD PORT="seqno_pos">0</TD><TD PORT="seqno_size">8</TD><TD>u8be</TD><TD PORT="seqno_type">seqno</TD></TR>
				<TR><TD PORT="format_pos">8</TD><TD PORT="format_size">8</TD><TD>u8be→ChunkFormat</TD><TD PORT="format_type">format</TD></TR>
				<TR><TD PORT="ns_pos">16</TD><TD PORT="ns_size">...</TD><TD>Tstr</TD><TD PORT="ns_type">ns</TD></TR>
				<TR><TD PORT="len_data_pos">...</TD><TD PORT="len_data_size">4</TD><TD>u4be</TD><TD PORT="len_data_type">len_data</TD></TR>
				<TR><TD PORT="data_pos">...</TD><TD PORT="data_size">len_data</TD><TD></TD><TD PORT="data_type">data</TD></TR>
				<TR><TD PORT="entries_count_pos">...</TD><TD PORT="entries_count_size">4</TD><TD>u4be</TD><TD PORT="entries_count_type">entries_count</TD></TR>
				<TR><TD PORT="digest_pos">...</TD><TD PORT="digest_size">28</TD><TD>Digest</TD><TD PORT="digest_type">digest</TD></TR>
			</TABLE>>];
		}
		subgraph cluster__rec_header {
			label="SclsFile::RecHeader";
			graph[style=dotted];

			rec_header__seq [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
				<TR><TD BGCOLOR="#E0FFE0">pos</TD><TD BGCOLOR="#E0FFE0">size</TD><TD BGCOLOR="#E0FFE0">type</TD><TD BGCOLOR="#E0FFE0">id</TD></TR>
				<TR><TD PORT="magic_pos">0</TD><TD PORT="magic_size">4</TD><TD></TD><TD PORT="magic_type">magic</TD></TR>
				<TR><TD PORT="version_pos">4</TD><TD PORT="version_size">2</TD><TD>u2be</TD><TD PORT="version_type">version</TD></TR>
				<TR><TD PORT="network_id_pos">6</TD><TD PORT="network_id_size">1</TD><TD>u1→NetworkId</TD><TD PORT="network_id_type">network_id</TD></TR>
				<TR><TD PORT="slot_no_pos">7</TD><TD PORT="slot_no_size">8</TD><TD>u8be</TD><TD PORT="slot_no_type">slot_no</TD></TR>
			</TABLE>>];
		}
		subgraph cluster__scls_record {
			label="SclsFile::SclsRecord";
			graph[style=dotted];

			scls_record__seq [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
				<TR><TD BGCOLOR="#E0FFE0">pos</TD><TD BGCOLOR="#E0FFE0">size</TD><TD BGCOLOR="#E0FFE0">type</TD><TD BGCOLOR="#E0FFE0">id</TD></TR>
				<TR><TD PORT="size_pos">0</TD><TD PORT="size_size">4</TD><TD>u4be</TD><TD PORT="size_type">size</TD></TR>
				<TR><TD PORT="record_type_pos">4</TD><TD PORT="record_type_size">1</TD><TD>u1</TD><TD PORT="record_type_type">record_type</TD></TR>
				<TR><TD PORT="record_data_pos">5</TD><TD PORT="record_data_size">...</TD><TD>switch (record_type)</TD><TD PORT="record_data_type">record_data</TD></TR>
			</TABLE>>];
scls_record__seq_record_data_switch [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
	<TR><TD BGCOLOR="#F0F2E4">case</TD><TD BGCOLOR="#F0F2E4">type</TD></TR>
	<TR><TD>0</TD><TD PORT="case0">RecHeader</TD></TR>
	<TR><TD>1</TD><TD PORT="case1">RecManifest</TD></TR>
	<TR><TD>16</TD><TD PORT="case2">RecChunk</TD></TR>
</TABLE>>];
		}
		subgraph cluster__namespace_info {
			label="SclsFile::NamespaceInfo";
			graph[style=dotted];

			namespace_info__seq [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
				<TR><TD BGCOLOR="#E0FFE0">pos</TD><TD BGCOLOR="#E0FFE0">size</TD><TD BGCOLOR="#E0FFE0">type</TD><TD BGCOLOR="#E0FFE0">id</TD></TR>
				<TR><TD PORT="len_ns_pos">0</TD><TD PORT="len_ns_size">4</TD><TD>u4be</TD><TD PORT="len_ns_type">len_ns</TD></TR>
				<TR><TD PORT="ns_info_pos">4</TD><TD PORT="ns_info_size">...</TD><TD>NsInfo</TD><TD PORT="ns_info_type">ns_info</TD></TR>
			</TABLE>>];
		}
		subgraph cluster__tstr {
			label="SclsFile::Tstr";
			graph[style=dotted];

			tstr__seq [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
				<TR><TD BGCOLOR="#E0FFE0">pos</TD><TD BGCOLOR="#E0FFE0">size</TD><TD BGCOLOR="#E0FFE0">type</TD><TD BGCOLOR="#E0FFE0">id</TD></TR>
				<TR><TD PORT="len_data_pos">0</TD><TD PORT="len_data_size">4</TD><TD>u4be</TD><TD PORT="len_data_type">len_data</TD></TR>
				<TR><TD PORT="data_pos">4</TD><TD PORT="data_size">len_data</TD><TD>str(UTF-8)</TD><TD PORT="data_type">data</TD></TR>
			</TABLE>>];
		}
		subgraph cluster__summary {
			label="SclsFile::Summary";
			graph[style=dotted];

			summary__seq [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
				<TR><TD BGCOLOR="#E0FFE0">pos</TD><TD BGCOLOR="#E0FFE0">size</TD><TD BGCOLOR="#E0FFE0">type</TD><TD BGCOLOR="#E0FFE0">id</TD></TR>
				<TR><TD PORT="created_at_pos">0</TD><TD PORT="created_at_size">...</TD><TD>Tstr</TD><TD PORT="created_at_type">created_at</TD></TR>
				<TR><TD PORT="tool_bytes_pos">...</TD><TD PORT="tool_bytes_size">...</TD><TD>Tstr</TD><TD PORT="tool_bytes_type">tool_bytes</TD></TR>
				<TR><TD PORT="comment_pos">...</TD><TD PORT="comment_size">...</TD><TD>Tstr</TD><TD PORT="comment_type">comment</TD></TR>
			</TABLE>>];
		}
	}
	scls_file__seq:record_type -> scls_record__seq [style=bold];
	rec_manifest__seq:summary_type -> summary__seq [style=bold];
	rec_manifest__seq:namespace_info_type -> namespace_info__seq [style=bold];
	namespace_info__seq:len_ns_type -> rec_manifest__seq:namespace_info__repeat [color="#404040"];
	rec_manifest__seq:root_hash_type -> digest__seq [style=bold];
	namespace_info__seq:len_ns_type -> ns_info__seq:namespaces_bytes_size [color="#404040"];
	ns_info__seq:digest_type -> digest__seq [style=bold];
	rec_chunk__seq:ns_type -> tstr__seq [style=bold];
	rec_chunk__seq:len_data_type -> rec_chunk__seq:data_size [color="#404040"];
	rec_chunk__seq:digest_type -> digest__seq [style=bold];
	scls_record__seq:record_data_type -> scls_record__seq_record_data_switch [style=bold];
	scls_record__seq_record_data_switch:case0 -> rec_header__seq [style=bold];
	scls_record__seq_record_data_switch:case1 -> rec_manifest__seq [style=bold];
	scls_record__seq_record_data_switch:case2 -> rec_chunk__seq [style=bold];
	scls_record__seq:record_type_type -> scls_record__seq:record_data_type [color="#404040"];
	namespace_info__seq:ns_info_type -> ns_info__seq [style=bold];
	tstr__seq:len_data_type -> tstr__seq:data_size [color="#404040"];
	summary__seq:created_at_type -> tstr__seq [style=bold];
	summary__seq:tool_bytes_type -> tstr__seq [style=bold];
	summary__seq:comment_type -> tstr__seq [style=bold];
}
